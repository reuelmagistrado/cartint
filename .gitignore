# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
local-*

# ─── CARTINT-specific ignores ─────────────────────────────────────────────────

# AI provider config (contains API keys — never commit)
.z-ai-config

# SQLite database (local data — each user generates their own)
/db/

# Logs
*.log
dev.log
dev.out.log
server.log

# Upload folder (session artifacts, not part of the source)
/upload/

# Download folder (session artifacts)
/download/

# Internal tooling
.claude
.zscripts
/skills/

# Caddyfile (sandbox-specific proxy config — not needed for local clones)
Caddyfile

# Mini-service logs
/mini-services/*.log
/tool-results/
