DATABASE_URL=file:./db/custom.db

# Optional AI provider. The app works without AI by using deterministic fallbacks.
# Supported values: openai, anthropic, google, ollama, custom
# AI_PROVIDER=ollama
# AI_BASE_URL=http://localhost:11434/v1
# AI_MODEL=llama3.2
# AI_API_KEY=

# Optional Tor SOCKS5 settings for .onion scraping.
# TOR_SOCKS_HOST=127.0.0.1
# TOR_SOCKS_PORT=9050

# Optional scraper settings.
# RANSOMLOOK_API_URL=https://www.ransomlook.io/api
# MAX_DOWNLOAD_BYTES=1000000
# MAX_EXTRACTED_TEXT=50000
# MAX_RETURN_CHARS=2000
# SCRAPE_TIMEOUT_TOR=45
# SCRAPE_MAX_WORKERS=5
