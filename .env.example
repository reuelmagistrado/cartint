# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite database file (relative path — works on any machine)
DATABASE_URL=file:./db/custom.db

# ─── AI Provider (REQUIRED) ───────────────────────────────────────────────────
# CARTINT requires an AI provider. Choose one:
#   zai       — Z.AI (default, uses .z-ai-config file instead of these vars)
#   openai    — OpenAI (gpt-4o)
#   anthropic — Anthropic Claude (claude-sonnet-4-20250514)
#   google    — Google Gemini (gemini-2.0-flash)
#   ollama    — Ollama (local, free, no API key needed)
#   custom    — Any OpenAI-compatible endpoint (Azure, Together AI, vLLM, etc.)
#
# If AI_PROVIDER is not set, defaults to "zai" which reads .z-ai-config.
# You can also configure AI via the in-app setup screen (first load).

AI_PROVIDER=zai
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# ─── Tor (optional, for dark-web scraping) ────────────────────────────────────
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050

# ─── RansomLook API (optional, for leak-site health monitoring) ───────────────
RANSOMLOOK_API_URL=https://www.ransomlook.io/api
RANSOMLOOK_API_KEY=

# ─── Dark-web Scraper Settings ────────────────────────────────────────────────
MAX_DOWNLOAD_BYTES=1000000
MAX_EXTRACTED_TEXT=50000
MAX_RETURN_CHARS=2000
SCRAPE_TIMEOUT_TOR=45
SCRAPE_MAX_WORKERS=5
SEARCH_MAX_WORKERS=5

# ─── Next.js URL (for the watchdog-scheduler mini-service) ────────────────────
NEXT_URL=http://localhost:3000
