DATABASE_URL=file:/home/z/my-project/db/custom.db

# Tor SOCKS5 proxy (for dark-web scraping)
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050

# LLM provider keys (at least one required for dark-web LLM filtering)
# The project uses z-ai-web-dev-sdk by default; these are for the multi-model
# dark-web scraper LLM filter (OpenAI-compatible).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434

# RansomLook API (health monitoring for ransomware leak-site mirrors)
RANSOMLOOK_API_URL=https://www.ransomlook.io/api
RANSOMLOOK_API_KEY=

# Dark-web scraper settings
MAX_DOWNLOAD_BYTES=1000000
MAX_EXTRACTED_TEXT=50000
MAX_RETURN_CHARS=2000
SCRAPE_TIMEOUT_TOR=45
SCRAPE_MAX_WORKERS=5
SEARCH_MAX_WORKERS=5
